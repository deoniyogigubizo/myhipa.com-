{
  "name": "myhipa.com",
  "version": "1.0.0",
  "private": true,
  "description": "myHipa - Rwanda's Premier E-commerce Marketplace",
  "author": "myHipa Team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:seed": "node scripts/seed.js",
    "seed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/lib/seed.ts",
    "db:reset": "node scripts/reset.js",
    "db:migrate": "node scripts/migrate.js",
    "worker:dev": "nodemon --exec node_modules/.bin/ts-node -r tsconfig-paths/register src/workers/index.ts",
    "worker:start": "node dist/workers/index.js",
    "queue:dev": "node_modules/.bin/bull-board --port 3001",
    "docker:build": "docker build -t myhipa/web .",
    "docker:run": "docker run -p 3000:3000 myhipa/web",
    "docker:compose": "docker-compose up -d",
    "docker:compose:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "deploy:staging": "AWS_PROFILE=myhipa npm run build && npm run docker:build && npm run ecs:deploy:staging",
    "deploy:prod": "AWS_PROFILE=myhipa npm run build && npm run docker:build && npm run ecs:deploy:prod",
    "ecs:deploy:staging": "echo 'Deploying to ECS staging...'",
    "ecs:deploy:prod": "echo 'Deploying to ECS production...'",
    "analyze": "ANALYZE=true next build"
  },
